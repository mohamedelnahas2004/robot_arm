<?xml version="1.0" ?>
<robot name="robot_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:property name="PI" value="3.14159"/>
<xacro:property name="effort" value="30.0"/>
<xacro:property name="velocity" value="10.0"/>

<material name="grey">
        <color rgba="0.5 0.5 0.5 1" />
    </material>

    <material name="blue">
        <color rgba="0 0 0.5 1" />
    </material>

<link name="world"/>

<joint name="world_joint" type="fixed">
  <origin xyz="0 0 0" rpy="0 0 ${PI/2}"/>
  <parent link="world"/>
  <child link="base_link"/>
</joint>

<link name="base_link">
  <inertial>
    <origin xyz="0.0009375030874740357 0.047087016508753216 0.06663230338123677" rpy="0 0 0"/>
    <mass value="1.0"/>
    <inertia ixx="0.063328" iyy="0.03095" izz="0.072371" ixy="-0.000434" iyz="0.001366" ixz="0.000108"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Link_1_1">
  <inertial>
    <origin xyz="0.0022188890353287776 -0.004863444449475237 0.08546835509394825" rpy="0 0 0"/>
    <mass value="0.5"/>
    <inertia ixx="0.061139" iyy="0.073854" izz="0.05669" ixy="0.00017" iyz="0.003835" ixz="-0.00148"/>
  </inertial>
  <visual>
    <origin xyz="-0.0 -0.000529 -0.111" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Link_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </visual>
  <collision>
    <origin xyz="-0.0 -0.000529 -0.111" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Link_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Link_2_1">
  <inertial>
    <origin xyz="0.055314283466519745 0.010843565259072822 0.11412354328486207" rpy="0 0 0"/>
    <mass value="0.5"/>
    <inertia ixx="0.128567" iyy="0.14463" izz="0.044463" ixy="3e-06" iyz="-0.003293" ixz="0.001539"/>
  </inertial>
  <visual>
    <origin xyz="0.05713 0.020356 -0.289378" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Link_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </visual>
  <collision>
    <origin xyz="0.05713 0.020356 -0.289378" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Link_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Link_3_1">
  <inertial>
    <origin xyz="-0.04178369242643258 -0.03913025368943244 0.01221763827191602" rpy="0 0 0"/>
    <mass value="0.5"/>
    <inertia ixx="0.012497" iyy="0.006916" izz="0.011789" ixy="-3.6e-05" iyz="0.001536" ixz="-8.1e-05"/>
  </inertial>
  <visual>
    <origin xyz="-0.043 0.019045 -0.550385" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Link_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </visual>
  <collision>
    <origin xyz="-0.043 0.019045 -0.550385" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Link_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Link_4_1">
  <inertial>
    <origin xyz="0.00021104999825562586 -0.06028834880207104 -0.0005408226217131773" rpy="0 0 0"/>
    <mass value="0.5"/>
    <inertia ixx="0.011624" iyy="0.011491" izz="0.017363" ixy="-9e-06" iyz="-7.1e-05" ixz="4e-06"/>
  </inertial>
  <visual>
    <origin xyz="-1e-06 0.15874 -0.57209" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Link_4_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </visual>
  <collision>
    <origin xyz="-1e-06 0.15874 -0.57209" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Link_4_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Link_5_1">
  <inertial>
    <origin xyz="0.0397291414278933 -0.012662394123331089 0.0007929187272999183" rpy="0 0 0"/>
    <mass value="0.5"/>
    <inertia ixx="0.000732" iyy="0.000958" izz="0.000907" ixy="-1.2e-05" iyz="-5e-06" ixz="5e-06"/>
  </inertial>
  <visual>
    <origin xyz="0.039011 0.279927 -0.570316" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Link_5_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </visual>
  <collision>
    <origin xyz="0.039011 0.279927 -0.570316" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Link_5_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Link_6_1">
  <inertial>
    <origin xyz="6.567946382108388e-08 -0.003042398377876454 -3.032508957279134e-07" rpy="0 0 0"/>
    <mass value="0.10343478090890781"/>
    <inertia ixx="5.2e-05" iyy="0.000103" izz="5.2e-05" ixy="-0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.000193 0.313762 -0.570316" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Link_6_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </visual>
  <collision>
    <origin xyz="-0.000193 0.313762 -0.570316" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Link_6_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Gripper_1">
  <inertial>
    <origin xyz="0.0036112727264542635 -0.014760653808445767 -0.00103677815369696" rpy="0 0 0"/>
    <mass value="0.5810486809925093"/>
    <inertia ixx="0.000385" iyy="0.000495" izz="0.000263" ixy="1e-05" iyz="-2e-06" ixz="3e-06"/>
  </inertial>
  <visual>
    <origin xyz="-0.000193 0.319847 -0.570316" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Gripper_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </visual>
  <collision>
    <origin xyz="-0.000193 0.319847 -0.570316" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Gripper_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Left_jaw_1">
  <inertial>
    <origin xyz="-0.011142702480351952 -0.009692440309284511 -0.009385792627785827" rpy="0 0 0"/>
    <mass value="0.05"/>
    <inertia ixx="1.1e-05" iyy="6e-06" izz="1.4e-05" ixy="2e-06" iyz="-0.0" ixz="-0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.007934 0.359845 -0.599867" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Left_jaw_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </visual>
  <collision>
    <origin xyz="-0.007934 0.359845 -0.599867" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Left_jaw_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Right_jaw_1">
  <inertial>
    <origin xyz="-0.008289104952972526 -0.009768535307719373 0.009395511902715814" rpy="0 0 0"/>
    <mass value="0.05"/>
    <inertia ixx="1.1e-05" iyy="6e-06" izz="1.4e-05" ixy="-1e-06" iyz="0.0" ixz="-1e-06"/>
  </inertial>
  <visual>
    <origin xyz="-0.007934 0.359845 -0.539867" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Right_jaw_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </visual>
  <collision>
    <origin xyz="-0.007934 0.359845 -0.539867" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/Right_jaw_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<joint name="joint_1" type="revolute">
  <origin xyz="0.0 0.000529 0.111" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="Link_1_1"/>
  <axis xyz="-0.0 0.0 1.0"/>
  <limit lower="-${PI}" upper="${PI}" effort="${effort}" velocity="${velocity}"/>
</joint>

<joint name="joint_2" type="revolute">
  <origin xyz="-0.05713 -0.020885 0.178378" rpy="0 0 0"/>
  <parent link="Link_1_1"/>
  <child link="Link_2_1"/>
  <axis xyz="1.0 -0.0 -0.0"/>
  <limit lower="-${PI/2}" upper="${PI/2}" effort="${effort}" velocity="${velocity}"/>
</joint>

<joint name="joint_3" type="revolute">
  <origin xyz="0.10013 0.001311 0.261007" rpy="-${PI/2} 0 0"/>
  <parent link="Link_2_1"/>
  <child link="Link_3_1"/>
  <axis xyz="-1.0 -0.0 0.0"/>
  <limit lower="-${PI/1.5}" upper="0.05" effort="${effort}" velocity="${velocity}"/>
</joint>

<joint name="joint_4" type="revolute">
  <origin xyz="-0.042999 -0.139695 0.021705" rpy="0 0 0"/>
  <parent link="Link_3_1"/>
  <child link="Link_4_1"/>
  <axis xyz="-0.0 1.0 -0.0"/>
  <limit lower="-${PI}" upper="${PI}" effort="${effort}" velocity="${velocity}"/>
</joint>

<joint name="joint_5" type="revolute">
  <origin xyz="-0.039012 -0.121187 -0.001774" rpy="0 0 0"/>
  <parent link="Link_4_1"/>
  <child link="Link_5_1"/>
  <axis xyz="-1.0 -0.0 0.0"/>
  <limit lower="-${PI/2}" upper="${PI/2}" effort="${effort}" velocity="${velocity}"/>
</joint>

<joint name="joint_6" type="revolute">
  <origin xyz="0.039204 -0.033835 0.0" rpy="0 0 0"/>
  <parent link="Link_5_1"/>
  <child link="Link_6_1"/>
  <axis xyz="-0.0 1.0 -0.0"/>
  <limit lower="-${PI}" upper="${PI}" effort="${effort}" velocity="${velocity}"/>
</joint>

<joint name="gripper" type="fixed">
  <origin xyz="0.0 -0.006085 0.0" rpy="0 0 0"/>
  <parent link="Link_6_1"/>
  <child link="Gripper_1"/>
</joint>

<joint name="jaw1" type="prismatic">
  <origin xyz="0.007741 -0.039998 0.029551" rpy="0 0 0"/>
  <parent link="Gripper_1"/>
  <child link="Left_jaw_1"/>
  <axis xyz="-0.0 0.0 -1.0"/>
  <limit upper="0.02" lower="-0.05" effort="100" velocity="100"/>
</joint>

<joint name="jaw2" type="prismatic">
  <origin xyz="0.007741 -0.039998 -0.030449" rpy="0 0 0"/>
  <parent link="Gripper_1"/>
  <child link="Right_jaw_1"/>
  <axis xyz="0.0 -0.0 1.0"/>
  <limit upper="0.02" lower="-0.05" effort="100" velocity="100"/>
</joint>

<!-- Camera Link -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.02 0.05 0.03"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- Camera Joint (Fixed to base_link) -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.0 -0.4 0.7" rpy="0 1.5708 0"/> <!-- x=40cm forward, z=60cm up, pitch=45deg down -->
  </joint>

<ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="joint_1">
      <command_interface name="position">
        <param name="min">-3.14159</param>
        <param name="max">3.14159</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="joint_2">
      <command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="joint_3">
      <command_interface name="position"><param name="min">-2.09</param><param name="max">0.05</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="joint_4">
      <command_interface name="position"><param name="min">-3.14</param><param name="max">3.14</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="joint_5">
      <command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="joint_6">
      <command_interface name="position"><param name="min">-3.14</param><param name="max">3.14</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="jaw1">
      <command_interface name="position"><param name="min">-0.05</param><param name="max">0.02</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="jaw2">
      <command_interface name="position"><param name="min">-0.05</param><param name="max">0.02</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find robot_arm_moveit_config)/config/ros2_controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="table_camera" type="camera">
      <update_rate>30.0</update_rate>
      <camera name="head">
        <horizontal_fov>1.39626</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
      <topic>/camera/image_raw</topic>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  
  <gazebo reference="Link_1_1">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  
  <gazebo reference="Link_2_1">
    <material>Gazebo/Orange</material>
  </gazebo>
  
  <gazebo reference="Link_3_1">
    <material>Gazebo/Orange</material>
  </gazebo>
  
  <gazebo reference="Link_4_1">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  
  <gazebo reference="Link_5_1">
    <material>Gazebo/Orange</material>
  </gazebo>
  
  <gazebo reference="Link_6_1">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  
  <gazebo reference="Left_jaw_1">
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="Right_jaw_1">
    <material>Gazebo/Black</material>
  </gazebo>
  
</robot>
